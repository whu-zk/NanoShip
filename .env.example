# NanoShip Configuration
# Copy this file to .env and fill in your values

# LLM Configuration (Required for AI features)
# Supported providers: deepseek, openai, anthropic
NANOSHIP_LLM_PROVIDER=deepseek
NANOSHIP_LLM_API_KEY=your-api-key-here
NANOSHIP_LLM_MODEL=deepseek-chat

# Optional: Custom base URL for LLM API
# NANOSHIP_LLM_BASE_URL=https://api.deepseek.com/v1

# SSH Configuration
NANOSHIP_SSH_KEY_PATH=~/.ssh/id_rsa
NANOSHIP_SSH_TIMEOUT=30

# Database
NANOSHIP_DB_PATH=~/.nanoship/nanoship.db

# Deployment
NANOSHIP_DEFAULT_DEPLOY_PATH=/opt/nanoship
NANOSHIP_AUTO_SSL=true

# Notifications (Optional)
# NANOSHIP_WEBHOOK_URL=https://hooks.slack.com/services/...
# NANOSHIP_WEBHOOK_TYPE=slack
